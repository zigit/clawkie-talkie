# Clawkie-Talkie client env template.
#
# Copy to `client/.env.local` and edit. Vite loads these at dev/build
# time; only variables prefixed `VITE_` are exposed to browser code.
#
# Hosted defaults need no variables.

# Custom rambly-compatible signaling server. Default:
# https://api.rambly.app
# VITE_SIGNAL_SERVER=https://signal.example.com

# Custom WebRTC ICE servers. Must be a JSON array of RTCIceServer objects.
# Invalid JSON logs a browser warning and falls back to hosted ICE defaults.
# VITE_ICE_SERVERS_JSON='[{"urls":"turn:turn.example.com:3478","username":"clawkie","credential":"change-me"}]'
